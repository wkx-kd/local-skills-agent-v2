# ============================================================
# Local Skills Agent v2 — 环境变量配置示例
# 复制为 .env 并填入真实值
# ============================================================

# ─── LLM 后端 ───────────────────────────────────────────────
# anthropic：使用 Anthropic SDK，对接 DashScope（阿里云千问）
# openai：使用 OpenAI SDK，对接 Ollama / vLLM / LM Studio 等本地模型
LLM_BACKEND=anthropic

# ─── Anthropic 后端（LLM_BACKEND=anthropic）──────────────────
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ─── OpenAI 兼容后端（LLM_BACKEND=openai）────────────────────
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen2.5:14b

# ─── PostgreSQL 数据库 ──────────────────────────────────────
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_secret
POSTGRES_DB=agent_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Milvus 向量数据库 ──────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ─── Embedding 模型 ─────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1024

# ─── Web 搜索 ───────────────────────────────────────────────
# 支持 tavily 或 serpapi
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx
# SERPAPI_API_KEY=xxxxxxxxxxxxxxxx

# ─── JWT 认证 ───────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-please-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── 应用配置 ───────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["http://localhost:5173"]
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50